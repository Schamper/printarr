# Printarr Environment Configuration
# Copy to .env and adjust as needed

# Container user/group IDs (for NAS permissions)
PUID=1000
PGID=1000

# Timezone
TZ=UTC

# Application port
PORT=6969

# Data directory (inside container)
DATA_DIR=/config

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Source API Keys ---

# Thingiverse: REQUIRED for search.
# Create an app at https://www.thingiverse.com/apps/create
# Use the "App Token" value from your app's page.
THINGIVERSE_API_TOKEN=
